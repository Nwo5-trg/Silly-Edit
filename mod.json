{
	"geode": "5.5.3",
	"gd": {
		"win": "2.2081",
		"android": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081"
	},
	"id": "nwo5.sillyedit",
	"name": "sillyedit",
	"version": "v0.1.0-beta.2",
	"developer": "Nwo5",
	"description": "betteredit/tinkers adopted little sister since 2.2081",
	"links": {
		"source": "https://github.com/Nwo5-trg/Silly-Edit"
	},
	"tags": ["editor", "bugfix", "customization", "enhancement", "interface", "utility", "offline"],
	"dependencies": {
        "geode.node-ids": ">=1.23.3",
		"nwo5.silly-api": ">=1.2.0",
		"hjfod.gmd-api": ">=1.5.0",
		"cvolton.level-id-api": ">=2.0.0",
		"blueblock6.cleanstartpos": {
			"version": ">=2.0.6",
			"required": false
		}
	},
	"resources": {
		"sprites": [
			"resources/*.png",
			"resources/object-tab-icons/*.png",
			"resources/logos/*.png",
			"resources/buttons/*.png"
		],
		"spritesheets": {
            "Sheet": [
				"resources/sheet/*.png"
			]
		}
	},
	"settings": {
		"general-title": {
			"type": "title",
			"name": "General"
		},
		"general-open-settings": {
			"type": "keybind",
			"name": "Open Settings",
			"category": "editor",
			"default": "Ctrl+Shift+P"
		},
		"ruler-title": {
			"type": "title",
			"name": "Ruler"
		},
		"ruler-create-measurement-key": {
			"type": "keybind",
			"name": "Create Measurement",
			"category": "editor",
			"default": "Ctrl+M"
		},
		"ruler-delete-last-measurement-key": {
			"type": "keybind",
			"name": "Delete Last Measurement",
			"description": "hold to delete all",
			"category": "editor",
			"default": "Ctrl+Shift+M"
		},
		"flood-fill-title": {
			"type": "title",
			"name": "Flood Fill"
		},
		"flood-fill-quick-fill-key": {
			"type": "keybind",
			"name": "Quick Fill",
			"category": "editor",
			"default": "K"
		},
		"better-scale-title": {
			"type": "title",
			"name": "Better Scale"
		},
		"better-scale-activate-scale-control": {
			"type": "keybind",
			"name": "Activate Scale Control",
			"category": "editor",
			"default": "Z"
		},
		"better-scale-activate-scale-xy-control": {
			"type": "keybind",
			"name": "Activate Scale XY Control",
			"category": "editor",
			"default": "X"
		},
		"free-snap-title": {
			"type": "title",
			"name": "Free Snap"
		},
		"free-snap-snap-selection": {
			"type": "keybind",
			"name": "Snap Selection",
			"category": "editor",
			"default": "N"
		},
		"zoom-input-title": {
			"type": "title",
			"name": "Zoom Input"
		},
		"zoom-input-zoom-in": {
			"type": "keybind",
			"name": "Zoom In",
			"category": "editor",
			"description": "doesnt require zoom input to be enabled ;3",
			"default": "Ctrl+="
		},
		"zoom-input-zoom-out": {
			"type": "keybind",
			"name": "Zoom Out",
			"category": "editor",
			"description": "doesnt require zoom input to be enabled ;3",
			"default": "Ctrl+Subtract"
		},
		"better-select-all-title": {
			"type": "title",
			"name": "Better Select All"
		},
		"better-select-all-select-all-key": {
			"type": "keybind",
			"name": "Select All",
			"category": "editor",
			"default": "Ctrl+Enter"
		},
		"better-select-all-select-all-left-key": {
			"type": "keybind",
			"name": "Select All Left",
			"category": "editor",
			"default": "Ctrl+Left"
		},
		"better-select-all-select-all-down-key": {
			"type": "keybind",
			"name": "Select All Down",
			"category": "editor",
			"default": "Ctrl+Down"
		},
		"better-select-all-select-all-up-key": {
			"type": "keybind",
			"name": "Select All Up",
			"category": "editor",
			"default": "Ctrl+Up"
		},
		"better-select-all-select-all-right-key": {
			"type": "keybind",
			"name": "Select All Right",
			"category": "editor",
			"default": "Ctrl+Right"
		}
	}
}